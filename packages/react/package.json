{
  "name": "@transactional-reducer/react",
  "version": "0.0.0",
  "description": "React bindings for transactional-reducer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest --run",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "transaction",
    "reducer",
    "state-management",
    "react",
    "hooks"
  ],
  "author": "anuoua <anuoua@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/anuoua/transactional-reducer#readme",
  "bugs": {
    "url": "https://github.com/anuoua/transactional-reducer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anuoua/transactional-reducer.git",
    "directory": "packages/react"
  },
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "@transactional-reducer/core": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@transactional-reducer/core": "workspace:*",
    "@types/react": "^19.1.6",
    "jsdom": "^29.1.1",
    "react": "^19.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
